DATABASE_URL="mysql://root:Geem@400@localhost:3306/geem_inventX# /etc/geem/env — Geem production environment
# Copy this file to /etc/geem/env and fill in all values
# Then: chmod 600 /etc/geem/env  chown geem:geem /etc/geem/env

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://geem:CHANGE_THIS_PASSWORD@localhost:5432/geem

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# ── Session / Auth ────────────────────────────────────────────────────────────
SESSION_SECRET=CHANGE_THIS_TO_64_RANDOM_CHARS

# ── CORS (comma-separated list of allowed origins) ────────────────────────────
ALLOWED_ORIGINS=https://geem.pk,https://www.geem.pk,https://crm.geem.pk,https://sim.geem.pk

# ── File uploads (local disk) ─────────────────────────────────────────────────
UPLOADS_DIR=/var/www/geem/uploads

# ── SIM Management API ────────────────────────────────────────────────────────
SIM_APP_KEY=your_sim_app_key_here
SIM_APP_SECRET=your_sim_app_secret_here

# ── AI / OpenAI (optional — for AI product fill feature) ─────────────────────
# Leave blank to disable AI features
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Clerk Authentication (shop customer login) ────────────────────────────────
# Get these from your Clerk dashboard (clerk.com)
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
